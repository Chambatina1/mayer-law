generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Appointment {
  id               String                 @id @default(cuid())
  clientEmail      String
  clientName       String
  clientPhone      String
  contactPref      String                 @default("email")
  streetAddress    String?
  city             String?
  state            String                 @default("FL")
  zip              String?
  county           String?
  service          String
  caseDescription  String
  issueDate        String?
  prevAttorney     Boolean                @default(false)
  courtDeadline    String?
  referralSource   String?
  urgency          Int                    @default(3)
  consentGiven     Boolean                @default(false)
  privacyConsent   Boolean                @default(false)
  date             String
  time             String
  status           String                 @default("pending")
  notes            String?
  confirmedAt      DateTime?
  reminder24h      Boolean                @default(false)
  reminder1h       Boolean                @default(false)
  createdAt        DateTime               @default(now())
  updatedAt        DateTime               @updatedAt
  documents        AppointmentDocument[]
}

model AppointmentDocument {
  id            String      @id @default(cuid())
  appointmentId String
  fileName      String
  fileSize      String?
  fileType      String?
  fileData      String?
  createdAt     DateTime    @default(now())
  appointment   Appointment @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
}

model Review {
  id          String   @id @default(cuid())
  clientName  String
  email       String
  rating      Int
  service     String?
  text        String?
  recommend   Boolean?
  featured    Boolean  @default(false)
  visible     Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model Client {
  id            String           @id @default(cuid())
  name          String
  email         String           @unique
  phone         String?
  contactPref   String           @default("email")
  streetAddress String?
  city          String?
  state         String           @default("FL")
  zip           String?
  county        String?
  referralSource String?
  tags          String           @default("")
  notes         String?
  lastActivity  DateTime         @updatedAt
  createdAt     DateTime         @default(now())
  documents     ClientDocument[]
  messages      ClientMessage[]
  invoices      Invoice[]
}

model ClientDocument {
  id         String   @id @default(cuid())
  clientId   String
  fileName   String
  fileSize   String?
  category   String?
  fileData   String?
  uploadedAt DateTime @default(now())
  client     Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model ClientMessage {
  id        String   @id @default(cuid())
  clientId  String
  sender    String
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model Invoice {
  id          String   @id @default(cuid())
  clientId    String
  amount      Float
  status      String   @default("pending")
  description String?
  date        String
  createdAt   DateTime @default(now())
  client      Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

model ContactSubmission {
  id        String   @id @default(cuid())
  name      String
  email     String
  phone     String?
  message   String
  read      Boolean  @default(false)
  createdAt DateTime @default(now())
}

model SiteSettings {
  id             String   @id @default("main")
  heroHeadline   String   @default("Resourcefully Relentless.")
  heroSubtitle   String   @default("Protecting your rights. Empowering your future.")
  aboutBio       String   @default("")
  phone          String   @default("(352) 494-3657")
  email          String   @default("Nicole@MayerLawFlorida.com")
  address        String   @default("Maitland, Florida")
  primaryColor   String   @default("#C17B6E")
  secondaryColor String   @default("#F0E6E0")
  bgColor        String   @default("#FBF7F4")
  updatedAt      DateTime @updatedAt
}
